# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_SAGE_VAULT_ADDRESS=
VITE_CELO_RPC_URL=https://forno.celo.org
# "celo-sepolia" for testnet, "celo" for mainnet
VITE_CHAIN=celo
# Set to "false" once a vault is deployed and VITE_SAGE_VAULT_ADDRESS is filled
VITE_ENABLE_MOCK_DATA=true

# ── Agent ─────────────────────────────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org
# "celo" for mainnet, "alfajores" for testnet
CHAIN=celo
# Hot-wallet private key — NEVER commit a real key
AGENT_PRIVATE_KEY=
# Optional: pay gas in G$ instead of CELO (MiniPay-compatible)
GDOLLAR_FEE_CURRENCY=
MAX_SLIPPAGE_BPS=100

# ── Contract addresses (filled after deployment) ──────────────────────────────
SAGE_VAULT_ADDRESS=
SAGE_AGENT_ADDRESS=
GOODDOLLAR_UBI_CONTRACT=
GDOLLAR_TOKEN=0x62B8B11039FcfE5aB0C56E502b1C372A3d2a9c7A
RESERVE_ASSET_TOKEN=
GOODDOLLAR_EXCHANGE_HELPER=
GOODDOLLAR_MARKET_MAKER=
AAVE_POOL_CELO=
ATOKEN_RESERVE_ASSET=

# ── Deployment parameters ─────────────────────────────────────────────────────
# The hot-wallet address that will call executeSaving on the vault
AGENT_EXECUTOR=
# Maximum G$ (18 decimals) allowed in a single executeSaving call
# e.g. 500e18 = 500 G$
MAX_SINGLE_DEPOSIT_GD=500000000000000000000
# Set from a live marketMaker.currentPrice(reserveToken) call before mainnet deploy.
# Leave 0 on testnet to disable the price-impact guard.
REFERENCE_GD_PER_STABLE_1E18=
# Agent registry metadata (optional, can be updated post-deploy)
AGENT_ENDPOINT=https://sage.app
AGENT_METADATA_URI=
MAX_PRICE_IMPACT_BPS=300
